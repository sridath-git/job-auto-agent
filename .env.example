GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
DATABASE_URL=sqlite:///data/job_auto_agent.db
GMAIL_QUERY=(from:(linkedin.com OR indeed.com OR greenhouse.io OR lever.co OR workday.com) OR subject:(job OR recruiter OR opportunity OR interview)) newer_than:90d
MATCH_MIN_SCORE=35
AI_TAILORING_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Free local Ollama option for AI resume tailoring and cover letters:
# AI_TAILORING_ENABLED=true
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:7b
# OPENAI_API_KEY=ollama
